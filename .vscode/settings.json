{
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "import (builtins.getFlake (builtins.toString ./.)).inputs.nixpkgs { }"
      },
      "formatting": {
        "command": ["nixfmt"]
      },
      "options": {
        "nix-darwin": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).darwinConfigurations.\"macbook-pro-m2\".options"
        },
        "nixos": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.matt-desktop.options"
        },
        "home-manager": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.matt-desktop.options.home-manager.users.type.getSubOptions []"
        }
      }
    }
  }
}
